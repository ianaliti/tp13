{
  "title": "Mon API Dashboard",
  "uid": "mon-api-dashboard",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total HTTP Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests per Service",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "{{job}} heap used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*cat.*|.*dog.*\"}[1m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
